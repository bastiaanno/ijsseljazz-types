{
  "name": "ijsseljazz-types",
  "version": "1.0.0",
  "description": "Shared TypeScript type definitions for IJsselJazz app and CMS",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "private": false,
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "bun run build",
    "prepare": "bun install"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "peerDependencies": {
    "firebase": "^10 || ^11 || ^12"
  },
  "exports": {
    ".": "./dist/index.js",
    "./types/*": "./dist/types/*"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ]
}
